# Local dev defaults are fine with no .env at all (SQLite + dev auth).
# DATABASE_URL=sqlite:///./reelie.db          # default; swap for a Postgres URL in prod
# DATABASE_URL=postgresql+psycopg://user:pass@host:5432/reelie
# JWT_SECRET=change-me-in-prod                 # dev falls back to a fixed dev secret
# AUTH_PROVIDER=dev                            # dev | clerk | auth0  (only 'dev' implemented)
