<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<!-- Export compliance: the app uses only standard HTTPS/TLS, which is exempt
	     encryption. Setting this to false skips the encryption question on every
	     App Store / TestFlight upload. -->
	<key>ITSAppUsesNonExemptEncryption</key>
	<false/>
	<!-- Local-networking exception ONLY (loopback/private hosts) so a debug build
	     can hit a local dev API over http. This is an Apple-sanctioned exception —
	     it does NOT weaken TLS for production traffic to reelie.io, which stays
	     HTTPS-enforced. It is not NSAllowsArbitraryLoads. -->
	<key>NSAppTransportSecurity</key>
	<dict>
		<key>NSAllowsLocalNetworking</key>
		<true/>
	</dict>
	<!-- Brand fonts (matching the web: Instrument Sans body + Space Grotesk display).
	     Files live in Resources/Fonts/ and are auto-bundled via the synchronized group;
	     UIAppFonts registers them so UIFont/Font.custom can resolve their PostScript names. -->
	<key>UIAppFonts</key>
	<array>
		<string>InstrumentSans-Regular.ttf</string>
		<string>InstrumentSans-Medium.ttf</string>
		<string>InstrumentSans-SemiBold.ttf</string>
		<string>InstrumentSans-Bold.ttf</string>
		<string>SpaceGrotesk-Medium.ttf</string>
		<string>SpaceGrotesk-SemiBold.ttf</string>
		<string>SpaceGrotesk-Bold.ttf</string>
	</array>
	<!-- Custom URL scheme the OAuth callback redirects to, so the web-auth session
	     hands control back to the app after a creator connects YouTube/Instagram. -->
	<key>CFBundleURLTypes</key>
	<array>
		<dict>
			<key>CFBundleURLName</key>
			<string>com.reelie.app.oauth</string>
			<key>CFBundleURLSchemes</key>
			<array>
				<string>reelie</string>
			</array>
		</dict>
	</array>
</dict>
</plist>
